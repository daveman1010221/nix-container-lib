# Justfile for a nix-container-lib dev container project.
#
# WORKFLOW
# --------
# 1. Edit container.dhall
# 2. just render-container   → regenerates container.nix
# 3. git add container.dhall container.nix && git commit
# 4. nix build .#devContainer
#
# container.nix is the pre-rendered Nix form of container.dhall.
# It must be committed alongside container.dhall so that nix build
# can import it without running Dhall (which requires network access
# that the Nix sandbox does not provide).

# Render container.dhall → container.nix
render-container:
    @echo "Rendering container.dhall → container.nix..."
    dhall-to-nix < container.dhall > container.nix
    @echo "Done. Commit container.nix alongside container.dhall."

# Type-check container.dhall without rendering
check-dhall:
    dhall type < container.dhall

# Build the container image
build:
    nix build .#devContainer -L

# Load the built image into Docker/Podman
load: build
    docker load < result || podman load -i result

# Enter the dev shell
dev:
    nix develop
